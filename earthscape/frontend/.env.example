# MongoDB
MONGODB_URI=mongodb://localhost:27017/earthscape

# NextAuth
NEXTAUTH_SECRET=your-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# SMTP (Nodemailer) — optional, uses Ethereal in dev if not set
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@earthscape.io

# Socket.io
SOCKET_PORT=3000
